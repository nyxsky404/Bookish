{
  "root": true,
  "env": {
    "es2022": true,
    "browser": false,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "ignorePatterns": ["node_modules/", "dist/", "*.config.js"],
  "rules": {
    "no-console": "off",
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": "error"
  }
}
